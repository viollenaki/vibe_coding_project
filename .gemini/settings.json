{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "read_file|grep_search|run_shell_command",
        "hooks": [
          {
            "name": "block-env",
            "type": "command",
            "command": "python .gemini/hooks/block-env.py"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "prettier",
            "type": "command",
            "command": "python .gemini/hooks/post-tool-prettier.py"
          }
        ]
      }
    ]
  }
}
